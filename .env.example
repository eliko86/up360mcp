# UP360 MCP Server - Environment Variables
# All data sources are public - no API keys required for basic operation

# Optional: Override cache TTLs (in milliseconds)
# CACHE_TTL_NEWS=1800000
# CACHE_TTL_JOBS=7200000
# CACHE_TTL_COMPANIES=86400000
# CACHE_TTL_DEMOGRAPHICS=604800000

# Optional: User-Agent for scraping
# USER_AGENT=UP360-MCP/1.0
